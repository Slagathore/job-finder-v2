{
  "manifest_version": 3,
  "name": "Job Finder Harvester",
  "version": "0.2.1",
  "description": "Harvest jobs from Indeed, LinkedIn & other boards into your local Job Finder desktop app. Data only ever goes to 127.0.0.1.",
  "icons": { "128": "icon128.png", "48": "icon48.png", "16": "icon16.png" },
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.indeed.com/*",
    "*://*.careerbuilder.com/*",
    "*://*.linkedin.com/*",
    "*://*.glassdoor.com/*",
    "*://*.ziprecruiter.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "Job Finder" },
  "content_scripts": [
    {
      "matches": ["*://*.indeed.com/*"],
      "js": ["content/scrape-indeed.js", "content/fieldcapture.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.careerbuilder.com/*"],
      "js": ["content/scrape-careerbuilder.js", "content/fieldcapture.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["content/scrape-linkedin.js", "content/fieldcapture.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.glassdoor.com/*"],
      "js": ["content/scrape-glassdoor.js", "content/fieldcapture.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.ziprecruiter.com/*"],
      "js": ["content/scrape-ziprecruiter.js", "content/fieldcapture.js"],
      "run_at": "document_idle"
    }
  ]
}
